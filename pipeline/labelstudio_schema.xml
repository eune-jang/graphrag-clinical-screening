<!--
  Label Studio Labeling Interface for Clinical Trial Eligibility Annotation
  ============================================================================

  Schema mapping (vs spec v1.2.2):
    - CriterionSpan          → "criterion_label" (InclusionCriterion / ExclusionCriterion)
    - ConceptMention         → "concept_label" (Drug / Condition / Observation / Procedure / Biomarker)
    - 13 cross-layer + IS_PART_OF → "relations" (single Relations group, value="…" 로 구분)

  Label Studio import 방법:
    1. http://localhost:8080 접속, 로그인
    2. Create Project → 이름 (예: KEYNOTE-671 Pilot)
    3. Labeling Setup 탭 → "Custom template" 선택
    4. 본 XML 내용 전체 복사 → 붙여넣기
    5. Save → 프로젝트 진입
    6. 좌측 Import 버튼 → tasks.json 또는 NCT03425643.json 업로드

  검수 화면 작동:
    - LLM pre-annotation 이 회색 highlight 로 보임 (predictions 영역)
    - 클릭 1번 = accept, 클릭 2번 = reject
    - hover 시 score / target_preferred_name / issues 가 보이지 않음 (Label Studio 한계)
      대신 좌측 패널 의 region 클릭 시 meta 가 보임
    - Filters 탭에서 score < 0.7 인 항목만 표시 가능 → flagged 만 빠르게 검수

  주의:
    - INCEpTION 의 auto_accept on-first-access 같은 자동 accept 기능은 없음
    - 30 trial batch 시 score 기반 sorting 으로 high-confidence 먼저 훑기
-->
<View>
  <Style>
    .htx-text {
      line-height: 1.8;
      font-size: 14px;
      padding: 12px;
    }
  </Style>
  <Header value="Clinical Trial Eligibility Annotation"/>

  <Labels name="criterion_label" toName="text">
    <Header value="Criterion (eligibility unit)"/>
    <Label value="InclusionCriterion" background="#dbeafe"/>
    <Label value="ExclusionCriterion" background="#fee2e2"/>
  </Labels>

  <!-- Entity labels: concept mention -->
  <Labels name="concept_label" toName="text">
    <Header value="Concept (clinical entity)"/>
    <Label value="Drug" background="#f59e0b"/>
    <Label value="Condition" background="#10b981"/>
    <Label value="Observation" background="#8b5cf6"/>
    <Label value="Procedure" background="#ec4899"/>
    <Label value="Biomarker" background="#06b6d4"/>
    <Label value="Concept" background="#6b7280"/>
  </Labels>

  <!-- Relation labels: 13 cross-layer + IS_PART_OF -->
  <Relations name="relations" choice="single">
    <!-- Layer 1 → Layer 1 -->
    <Relation value="IS_PART_OF" background="#9ca3af"/>
    <!-- Layer 1 → Layer 3 (cross-layer) -->
    <Relation value="REQUIRES_CONDITION" background="#10b981"/>
    <Relation value="REQUIRES_TREATMENT" background="#f59e0b"/>
    <Relation value="REQUIRES_BIOMARKER" background="#06b6d4"/>
    <Relation value="REQUIRES_STATUS" background="#3b82f6"/>
    <Relation value="REQUIRES_PROCEDURE" background="#ec4899"/>
    <Relation value="EXCLUDES_CONDITION" background="#dc2626"/>
    <Relation value="EXCLUDES_TREATMENT" background="#b91c1c"/>
    <Relation value="EXCLUDES_PROCEDURE" background="#991b1b"/>
    <Relation value="EXCLUDES_COMEDICATION" background="#ef4444"/>
    <Relation value="EXCLUDES_STATUS" background="#f97316"/>
    <Relation value="HAS_VALUE" background="#a855f7"/>
    <Relation value="HAS_TEMPORAL" background="#7c3aed"/>
    <Relation value="INCLUDES_EXCEPTION" background="#fbbf24"/>
  </Relations>

  <!-- Main text view -->
  <Text name="text" value="$text" granularity="symbol"/>
</View>