# Template for Streamlit secrets.
#
# This file is committed to git as a template ONLY. Do NOT put real
# passwords here — the repo is public.
#
# Local development:
#   Copy this file to `.streamlit/secrets.toml` (which is .gitignored)
#   and edit the values there.
#
# Production (Streamlit Community Cloud):
#   Set the actual values via the Streamlit Cloud dashboard
#   (Manage app → Settings → Secrets). They are NEVER stored in this repo.

# Single shared password — gates URL access for both annotators.
# Pick something hard to guess (12+ chars, not a dictionary word).
# Communicate to the other annotator out-of-band (Signal / encrypted email).
SHARED_PASSWORD = "REPLACE_ME_VIA_STREAMLIT_CLOUD_DASHBOARD"
